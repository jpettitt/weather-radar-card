{
  "name": "weather-radar-card",
  "version": "3.7.2-beta2",
  "type": "module",
  "description": "A rain radar card using data from RainViewer",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "custom-cards"
  ],
  "module": "weather-radar-card.js",
  "repository": "git@github.com:jpettitt/weather-radar-card.git",
  "author": "Simon Ratcliffe",
  "contributors": [
    "John Pettitt"
  ],
  "license": "MIT",
  "dependencies": {
    "@lit-labs/scoped-registry-mixin": "^1.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "custom-card-helpers": "^1.9.0",
    "home-assistant-js-websocket": "^9.4.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lit": "^3.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.1",
    "rollup": "^4.62.2",
    "rollup-plugin-serve": "^1.1.0",
    "rollup-plugin-string": "^3.0.0",
    "rollup-plugin-typescript2": "^0.37.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "lit": "^3.3.3",
    "lit-html": "^3.3.3",
    "lit-element": "^4.2.2",
    "@lit/reactive-element": "^2.1.2",
    "serialize-javascript": "^7.0.6"
  },
  "scripts": {
    "start": "rollup -c rollup.config.dev.js --watch",
    "build": "npm run lint && npm run rollup",
    "lint": "eslint src/*.ts",
    "rollup": "rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ha:init": "mkdir -p .dev/ha-config && cp -n .dev/configuration.yaml.example .dev/ha-config/configuration.yaml || true",
    "ha:up": "npm run ha:init && docker compose up -d && echo 'HA starting at http://localhost:8123 (first boot may take a minute)'",
    "ha:down": "docker compose down",
    "ha:logs": "docker compose logs -f ha",
    "ha:reset": "docker compose down && rm -rf .dev/ha-config && echo 'HA config wiped. Run npm run ha:up for a fresh instance.'"
  }
}
